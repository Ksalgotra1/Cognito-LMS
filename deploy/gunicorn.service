[Unit]
Description=gunicorn daemon for Cognito LMS
Requires=gunicorn.socket
After=network.target

[Service]
User=cognito
Group=www-data
WorkingDirectory=/home/cognito/app/backend
EnvironmentFile=/home/cognito/app/backend/.env
ExecStart=/home/cognito/app/backend/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/run/gunicorn.sock \
          mysite.wsgi:application

[Install]
WantedBy=multi-user.target
