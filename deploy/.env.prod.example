# Cognito LMS — Production Environment Variables
# Copy to: /home/cognito/app/backend/.env
# NEVER commit this file to git (already in .gitignore)

# ─── Django Core ──────────────────────────────────────────────────────────────
DJANGO_ENV=prod

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET

# Comma-separated — no spaces, no quotes
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Managed Postgres (recommended) or self-hosted
DATABASE_URL=postgres://cognito_user:CHANGE_ME@localhost:5432/cognito

# ─── Redis ────────────────────────────────────────────────────────────────────
# db0 → Celery broker + result backend
# db1 → Django cache (auto-derived from REDIS_URL in base.py)
REDIS_URL=redis://localhost:6379/0

# ─── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# ─── Site URLs ────────────────────────────────────────────────────────────────
SITE_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai
AI_PROVIDER=ollama
AI_MODEL=llama3

# Only required when AI_PROVIDER=openai
# GitHub PAT with models:read scope, or OpenAI API key
AI_API_KEY=
